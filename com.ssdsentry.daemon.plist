<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.ssdsentry.daemon</string>

  <key>ProgramArguments</key>
  <array>
    <string>__PYTHON3__</string>
    <string>/usr/local/ssd-sentry/ssd_sentry_monitor.py</string>
  </array>

  <key>RunAtLoad</key>
  <true/>

  <key>KeepAlive</key>
  <true/>

  <key>UserName</key>
  <string>root</string>

  <key>ProcessType</key>
  <string>Background</string>
</dict>
</plist>
